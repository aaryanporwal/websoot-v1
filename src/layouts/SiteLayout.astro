---
import { getCollection } from "astro:content";
import CommandSwitcher, {
  type CommandItem,
} from "../../components/CommandSwitcher";
import "../../styles/globals.css";
import { postHref, postSummary, sortPosts } from "../lib/posts";

type Props = {
  title?: string;
  description?: string;
  canonicalPath?: string;
  bodyClass?: string;
};

const {
  title = "Aaryan Porwal · Web Engineer",
  description = "Personal site of Aaryan Porwal, a web engineer who builds fast, resilient web products. Work, writing, and a cat named Anya who screens the inbox.",
  canonicalPath = Astro.url.pathname,
  bodyClass = "bg-body text-white antialiased",
} = Astro.props;

const canonical = new URL(canonicalPath, Astro.site ?? "https://aaryanporwal.com");
const posthogKey = import.meta.env.PUBLIC_POSTHOG_KEY;
const posthogHost =
  import.meta.env.PUBLIC_POSTHOG_HOST || "https://eu.i.posthog.com";

const posts = sortPosts(
  await getCollection("blog", ({ data }) => data.draft !== true),
);

const commands: CommandItem[] = [
  {
    title: "Home",
    href: "/",
    section: "Navigation",
    description: "Back to the top",
  },
  {
    title: "Work",
    href: "/#work",
    section: "Navigation",
    description: "Selected projects",
  },
  {
    title: "Skills",
    href: "/#skills",
    section: "Navigation",
    description: "Tools and technologies",
  },
  {
    title: "Blog",
    href: "/blog/",
    section: "Navigation",
    description: "Writing archive",
  },
  {
    title: "Contact",
    href: "/#contact",
    section: "Navigation",
    description: "Get in touch",
  },
  {
    title: "GitHub",
    href: "https://github.com/aaryanporwal?tab=repositories",
    section: "Social",
    description: "Projects and repositories",
    external: true,
  },
  {
    title: "LinkedIn",
    href: "https://www.linkedin.com/in/aaryan-porwal/",
    section: "Social",
    description: "Professional profile",
    external: true,
  },
  {
    title: "Scrapbook",
    href: "https://scrapbook.hackclub.com/aaryan",
    section: "Social",
    description: "Build notes and updates",
    external: true,
  },
  ...posts.map((post) => ({
    title: post.data.title,
    href: postHref(post),
    section: "Writing" as const,
    description: postSummary(post),
  })),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="shortcut icon" href="/favicon.ico" sizes="any" />
    <link
      href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&f[]=general-sans@400,500,600&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        const fallback = "default";
        const themes = new Set([
          "default",
          "light",
          "gruvbox",
          "everforest",
          "nature",
          "rose-pine",
        ]);
        const saved = localStorage.getItem("aaryanporwal-theme");
        const theme = saved === "dark" ? fallback : themes.has(saved) ? saved : fallback;
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    {
      posthogKey && (
        <script data-posthog-key={posthogKey} data-posthog-host={posthogHost}>
          import posthog from "posthog-js";

          const script = document.currentScript as HTMLScriptElement | null;
          const key = script?.dataset.posthogKey;
          const host = script?.dataset.posthogHost || "https://eu.i.posthog.com";

          if (key) {
            posthog.init(key, {
              api_host: host,
              defaults: "2025-05-24",
            });
          }
        </script>
      )
    }
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <slot />
    <script>
      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (!target.closest("[data-command-switcher-trigger]")) return;

        window.dispatchEvent(new CustomEvent("command-switcher:open"));
      });
    </script>
    <CommandSwitcher client:load commands={commands} />
  </body>
</html>
